{
  "version": "test-layout-top-bottom",
  "scheduler": { "enabled": false },
  "theme": { "name": "dark" },
  "layout": { "type": "top-bottom", "gap": "2rem", "padding": "2rem" },
  "widgets": [
    { "type": "clock", "id": "clock-top", "size": { "width": "auto", "height": "auto" }, "options": { "showSeconds": true, "showDate": false, "hourFormat": "12", "timezone": "Asia/Kolkata" } },
    { "type": "clock", "id": "clock-bottom", "size": { "width": "auto", "height": "auto" }, "options": { "showSeconds": false, "showDate": true, "hourFormat": "12", "timezone": "Asia/Kolkata" } }
  ]
}
