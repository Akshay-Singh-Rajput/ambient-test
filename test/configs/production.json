{
  "version": "test-production",
  "scheduler": { "enabled": false },
  "theme": { "name": "dark" },
  "layout": { "type": "center", "gap": "2rem", "padding": "2rem", "columns": 2 },
  "widgets": [
    {
      "type": "clock",
      "id": "test-clock",
      "size": { "width": "auto", "height": "auto" },
      "options": {
        "showSeconds": true,
        "showDate": true,
        "hourFormat": "12",
        "timezone": "Asia/Kolkata"
      }
    }
  ]
}
